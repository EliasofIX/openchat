# ──────────────────────────────────────────────────────────────────────
# Open AI Chat UI — environment variables
#
# Copy this file to `.env.local` and fill in real values. The `.env.local`
# file is git-ignored, so your secrets will never reach the public repo.
#
#   cp .env.example .env.local
#
# ──────────────────────────────────────────────────────────────────────

# Required. Your OpenRouter API key. Get one at https://openrouter.ai/keys
# This stays on the server and is never exposed to the browser.
OPENROUTER_API_KEY=

# Optional. The default model to use. Any OpenRouter model id is valid.
# See https://openrouter.ai/models for the full list.
# Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   meta-llama/llama-3.3-70b-instruct
#   google/gemini-2.0-flash-001
DEFAULT_MODEL=openai/gpt-4o-mini
# Optional. Default Ollama server URL when using the local provider.
OLLAMA_BASE_URL=http://localhost:11434

# Optional. Default Ollama model when none is selected in settings.
# OLLAMA_MODEL=llama3.2

# Optional. Sent to OpenRouter as the `HTTP-Referer` and `X-Title` headers.
# OpenRouter uses these to attribute traffic on their leaderboards.
# Safe to expose — these are public-facing strings, not secrets.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Open AI Chat UI
